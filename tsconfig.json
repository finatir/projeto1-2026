{
  "compilerOptions": {
 
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext"],

    "types": ["node"],
    "typeRoots": ["../node_modules/@types", "./node_modules/@types"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0"
  },
  "include": ["*.ts", "src/**/*"],
  "exclude": ["node_modules"]
}
